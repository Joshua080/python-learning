def main():
    time = input("Please enter the time: ")
    if 7.00 <= convert(time) <= 8.00 :
        print("breakfast time")
    elif 12.00 <= convert(time) <= 13.00 :
        print("lunch time")
    elif 18.00 <= convert(time) <= 19.00 :
        print("dinner time")

def convert(time):
    hrs = float(time.split(":")[0])
    min = float(time.split(":")[1])
    total = hrs + (min/60)
    return total