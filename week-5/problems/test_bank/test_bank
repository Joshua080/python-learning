from bank import value
import pytest

def test_uppercase():
    assert value("HELLO") == 0
    assert value("Goodmorning") == 100
    assert value("HEY") == 20

def test_num():
    assert value("20") == 100
    assert value("-1") == 100

def test_punctuation():
    assert value("!hello") == 100
    assert value(".goodmorning") == 100
